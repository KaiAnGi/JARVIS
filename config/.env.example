# Jarvis Assistant - Environment Variables
# Copy this file to .env and fill in your values

# Google OAuth (for Gmail and Calendar plugins)
# 1. Go to https://console.cloud.google.com
# 2. Create a project or select existing
# 3. Enable Gmail API and Google Calendar API
# 4. Create OAuth 2.0 credentials (Desktop app)
# 5. Download credentials.json and place it in config/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vosk model language (default: en-us)
# Download models from https://alphacephei.com/vosk/models
VOSK_MODEL_LANGUAGE=en-us

# Ollama model (default: qwen3:8b)
JARVIS_OLLAMA_MODEL=qwen3:8b

# Discord Webhook URL (for notifications)
# 1. Go to your Discord server settings > Integrations > Webhooks
# 2. Create a webhook and copy the URL
DISCORD_WEBHOOK_URL=

# Spotify API (for music control)
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create an app, get Client ID and Secret
# 3. Add http://localhost:8888/callback as Redirect URI
# 4. Run the app and authenticate once
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_TOKEN_PATH=config/spotify_token.json
